generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())

  name  String
  email String @unique

  password String?

  googleId String? @unique
  avatar   String?

  role Role @default(WRITER)

  isActive Boolean @default(true)

  articles Article[]

  revisions         ArticleRevision[]
  approvedRevisions ArticleRevision[] @relation("RevisionApprover")

  activityLogs ActivityLog[]

  resetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id String @id @default(uuid())

  title   String
  content String

  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  views       Int @default(0)
  healthScore Int @default(0)

  version Int @default(1)

  slug   String @unique
  status Status @default(DRAFT)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  revisions ArticleRevision[]

  scheduledAt DateTime?
  publishedAt DateTime?

  logs ActivityLog[]
  lastContentUpdate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ArticleRevision {
  id String @id @default(uuid())

  articleId String
  article   Article @relation(fields: [articleId], references: [id])

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  title   String
  content String

  categoryId String?

  summary String?

  baseVersion Int

  status RevisionStatus @default(PENDING)

  approvedById String?

  approvedBy User? @relation(name: "RevisionApprover", fields: [approvedById], references: [id])

  approvedAt DateTime?

  createdAt DateTime @default(now())
}

model Category {
  id String @id @default(uuid())

  name String

  articles Article[]
}

model Tag {
  id String @id @default(uuid())

  name String
}

model ActivityLog {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  articleId String?
  article   Article? @relation(fields: [articleId], references: [id])

  action String

  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id String @id @default(uuid())

  token String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id])

  expiresAt DateTime

  createdAt DateTime @default(now())
}

model WikiBlock {
  id          String   @id @default(uuid())
  key         String   @unique
  title       String
  content     String   @db.Text
  imageUrl    String?
  position    Int
  isVisible   Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WikiSettings {
  id String @id @default(uuid())

  heroTitle       String? @db.Text
  heroSubtitle    String? @db.Text

  featuredTitle   String? @db.Text
  featuredContent String? @db.Text

  announcementTitle   String? @db.Text
  announcementContent String? @db.Text

  communityTitle   String? @db.Text
  communityContent String? @db.Text

  linksTitle   String? @db.Text
  linksContent String? @db.Text

  featuredArticle1Id String?
  featuredArticle2Id String?
  featuredArticle3Id String?

  backgroundUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  EDITOR
  WRITER
}

enum Status {
  DRAFT
  PUBLISHED
}

enum RevisionStatus {
  PENDING
  APPROVED
  REJECTED
  OUTDATED
}
